# Pinterest credentials — DO NOT commit the real .env file
PINTEREST_EMAIL=you@example.com
PINTEREST_PASSWORD=your-password

# Optional: absolute path to the CSV to upload.
# Can also be passed via the --csv CLI flag.
PINTEREST_CSV_PATH=/absolute/path/to/pinterest_bulk_upload.csv

# Optional: seconds to wait for manual CAPTCHA/2FA resolution (default 120)
PINTEREST_MANUAL_WAIT=120

# Optional: run browser headless (default false per PRD — visible execution)
PINTEREST_HEADLESS=false

# Optional: directory for logs and screenshots (default ./artifacts)
PINTEREST_ARTIFACTS_DIR=artifacts
