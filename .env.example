# Pinterest Tech Trends - Environment Variables
# Copy this file to ~/.hermes/.env (not the repo directory) and fill in all values
# The deploy script will copy this template; you must edit it with real credentials

# ============================================================
# REQUIRED: Firecrawl API Key (for web scraping Job 1)
# ============================================================
# Get your key from: https://www.firecrawl.dev/
# Job 1 uses this to scrape trending products from multiple sources
FIRECRAWL_API_KEY=fc-your-key-here

# ============================================================
# REQUIRED: Gmail SMTP (for email reports - Job 1)
# ============================================================
# Email address: your Gmail address
EMAIL_ADDRESS=your_email@gmail.com

# App password (NOT your regular Gmail password!)
# Generate at: https://myaccount.google.com/apppasswords
# Select "Mail" and "Windows Computer", then copy the 16-char password
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP server settings (usually don't need to change these)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ============================================================
# REQUIRED: Telegram Bot (for notifications - all 3 jobs)
# ============================================================
# Bot token: Create a bot via @BotFather on Telegram, then copy the token
# Format: 123456789:ABCdefGHIjklmnoPQRstuvWXYZ_1a2b3c4d
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram numeric user ID (not the bot's ID!)
# Get it: Send @userinfobot any message on Telegram, it will reply with your ID
# Format: 1234567890 (just digits)
TELEGRAM_HOME_CHANNEL=your_user_id_here

# Allowed Telegram users (comma-separated numeric IDs)
# Usually just your own ID, but you can add other users
TELEGRAM_ALLOWED_USERS=your_user_id_here

# ============================================================
# REQUIRED: Pinterest Credentials (for pin uploads - Job 3)
# ============================================================
# Your Pinterest account email
PINTEREST_EMAIL=your_pinterest_email@gmail.com

# Your Pinterest account password
# WARNING: This will be stored in plaintext in .env
# Consider using a dedicated Pinterest account with a strong, unique password
PINTEREST_PASSWORD=your_pinterest_password_here

# Pinterest board name (must match exactly - case sensitive)
# Your board: https://www.pinterest.com/YOUR_USERNAME/BOARD_NAME/
PINTEREST_BOARD_NAME=SmartyPants2786

# ============================================================
# OPTIONAL: Google Drive (for CSV storage and polling)
# ============================================================
# If you want to store generated CSVs and pin files on Google Drive:
# 1. Visit: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable the Google Drive API
# 4. Create a "Service Account" and download the JSON key file
# 5. Share your Google Drive folders with the service account email
# 6. Base64 encode the JSON file and paste it here, OR
# 7. Just paste the folder IDs you want to use (Job 1 emails CSVs to you instead)

# Google Drive folder IDs (find in URL: https://drive.google.com/drive/folders/FOLDER_ID)
# Folder for storing CSV reports
GOOGLE_DRIVE_CSV_FOLDER_ID=1w-XAxZccQ4wk4NOKwm2YDusouLvO-a6L

# Folder for storing generated pin JSON files
GOOGLE_DRIVE_PINS_FOLDER_ID=1p4JS0GDHVny1IBDbcSNghgKHaY_64E5D

# ============================================================
# OPTIONAL: LM Studio (for enhanced product descriptions)
# ============================================================
# If running LM Studio locally for AI-powered features:
# Download at: https://lmstudio.ai/

# LM Studio API endpoint (default: local)
LM_STUDIO_BASE_URL=http://192.168.1.7:1234/v1

# Model name (must be loaded in LM Studio)
# Common: qwen2.5-coder-14b-instruct, claude-3.7-sonnet-reasoning-gemma3-12b
LM_STUDIO_MODEL=zai-org/glm-4.7-flash

# LM Studio doesn't require auth but can use a dummy key
LM_STUDIO_API_KEY=not-needed

# ============================================================
# OPTIONAL: OpenRouter (alternative to LM Studio)
# ============================================================
# If using OpenRouter instead of local LM Studio:
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# ============================================================
# OPTIONAL: Amazon Affiliate Tag
# ============================================================
# Your Amazon Associates affiliate tag (for commission links)
# Sign up at: https://affiliate-program.amazon.com/
# If empty, will generate standard Amazon product links without affiliate tracking
AMAZON_AFFILIATE_TAG=allitechstore-20

# ============================================================
# DEPLOYMENT & RUNTIME
# ============================================================
# Usually don't need to change these:

# Hermes home directory (where scripts are deployed)
# Default: ~/.hermes
HERMES_HOME=~/.hermes

# Temporary CSV path for scraper output
CSV_PATH=/tmp/trending_tech_products.csv
